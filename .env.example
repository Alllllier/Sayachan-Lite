# ============================================
# Sayachan Lite - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control
# ============================================

# ----- Backend -----
# MongoDB 连接串（必需）
MONGO_URI=mongodb://localhost:27017/personal-os-lite

# 后端服务端口
PORT=3001

# 前端允许跨域地址（CORS origin）
# 部署时需要修改为实际的前端地址
FRONTEND_ORIGIN=http://localhost:5173

# GLM AI API Key（后端使用，用于 Notes/Projects AI suggestion）
# 配置后，Notes 的 "AI Tasks" 和 Projects 的 "Generate Next Step" 将使用真实 AI
# 不配置时使用 fallback mock 数据
GLM_API_KEY=your_glm_api_key_here

# ----- Frontend -----
# 后端 API 地址（前端需要）
# 部署时需要修改为实际的后端地址
VITE_API_BASE_URL=http://localhost:3001

# VITE_GLM_API_KEY（已弃用）
# AI 调用已迁移至后端，此变量已不再使用
# 保留此行仅为兼容性，请勿再配置
# VITE_GLM_API_KEY=deprecated

# ----- Development -----
# 前端开发端口（仅开发环境使用）
FRONTEND_PORT=5173

#!/bin/sh
#
# Pre-commit hook for Sayachan Lite
# 当 architecture 相关文件改动时，提醒更新文档

# 获取要提交的改动文件列表
STAGED_FILES=$(git diff --cached --name-only)

# Architecture 相关文件模式
ARCH_FILES="backend/src/(models|routes)/.*\.js|frontend/src/services/.*\.js|frontend/src/router/.*\.js"
DOC_FILES="\.docs/architecture-audit/.*\.md|CLAUDE\.md"

# 检查是否有 architecture 文件被修改
ARCH_CHANGED=false
DOC_CHANGED=false

for file in $STAGED_FILES; do
    # 检查是否修改了架构文件
    if echo "$file" | grep -qE "backend/src/(models|routes)/.*\.js|frontend/src/(services|router)/.*\.js"; then
        ARCH_CHANGED=true
    fi
    # 检查是否修改了 style.css（基线 CSS）
    if echo "$file" | grep -qE "frontend/src/style\.css"; then
        ARCH_CHANGED=true
    fi
    # 检查是否同时更新了文档
    if echo "$file" | grep -qE "\.docs/architecture-audit/.*\.md|CLAUDE\.md"; then
        DOC_CHANGED=true
    fi
done

# 如果修改了架构文件但没有更新文档，给出警告
if [ "$ARCH_CHANGED" = true ] && [ "$DOC_CHANGED" = false ]; then
    echo ""
    echo "⚠️  WARNING: Architecture-related files have been modified but documentation has not been updated."
    echo ""
    echo "Modified architecture files:"
    echo "$STAGED_FILES" | grep -E "backend/src/(models|routes)/.*\.js|frontend/src/(services|router)/.*\.js|frontend/src/style\.css" | sed 's/^/  - /'
    echo ""
    echo "Please check if the following documents need to be updated:"
    echo "  - .docs/architecture-audit/01-技术栈.md (Technical Stack)"
    echo "  - .docs/architecture-audit/03-后端API接口.md (API Documentation)"
    echo "  - .docs/architecture-audit/04-Roadmap.md (Roadmap)"
    echo "  - .docs/architecture-audit/05-开发规范与约束.md (CSS Baseline)"
    echo "  - CLAUDE.md (Claude Context)"
    echo ""
    echo "To bypass this check, use: git commit --no-verify"
    echo ""

    # 在 Windows Git Bash 中，使用 read -p 可能有问题，所以直接退出
    exit 1
fi

exit 0

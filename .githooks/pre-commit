#!/bin/sh
#
# Repo-owned pre-commit hook for Sayachan Lite.
# Blocks commits when architecture-sensitive code changes are staged
# without a matching update under docs/architecture/.

STAGED_FILES=$(git diff --cached --name-only)

ARCH_CODE_PATTERN="backend/src/models/.*\.js|backend/src/routes/.*\.js|backend/src/ai/bridge\.js|frontend/src/stores/.*\.js|frontend/src/services/(aiService|chatService|dashboardContextService|taskService)\.js|frontend/src/router/.*\.js|frontend/src/components/ChatEntry\.vue"
ARCH_DOC_PATTERN="docs/architecture/.*\.md"
MANIFEST_PATTERN="backend/package\.json|frontend/package\.json"
PMO_DOC_PATTERN="docs/pmo/.*\.md|docs/ai-ops/.*\.md"
PMO_SYNC_PATTERN="docs/guides/documentation-sync\.md"

ARCH_CODE_CHANGED=false
ARCH_DOC_CHANGED=false
MANIFEST_CHANGED=false
PMO_DOC_CHANGED=false
PMO_SYNC_CHANGED=false

for file in $STAGED_FILES; do
    if echo "$file" | grep -qE "$ARCH_CODE_PATTERN"; then
        ARCH_CODE_CHANGED=true
    fi

    if echo "$file" | grep -qE "$ARCH_DOC_PATTERN"; then
        ARCH_DOC_CHANGED=true
    fi

    if echo "$file" | grep -qE "$MANIFEST_PATTERN"; then
        MANIFEST_CHANGED=true
    fi

    if echo "$file" | grep -qE "$PMO_DOC_PATTERN"; then
        PMO_DOC_CHANGED=true
    fi

    if echo "$file" | grep -qE "$PMO_SYNC_PATTERN"; then
        PMO_SYNC_CHANGED=true
    fi
done

if [ "$ARCH_CODE_CHANGED" = true ] && [ "$ARCH_DOC_CHANGED" = false ]; then
    echo ""
    echo "WARNING: Architecture-sensitive code changed, but docs/architecture/ was not updated."
    echo ""
    echo "Changed files:"
    echo "$STAGED_FILES" | grep -E "$ARCH_CODE_PATTERN" | sed 's/^/  - /'
    echo ""
    echo "Please review whether one or more of these docs should change:"
    echo "  - docs/architecture/system-baseline.md"
    echo "  - docs/architecture/runtime-workflow.md"
    echo "  - docs/architecture/backend-api.md"
    echo "  - docs/architecture/roadmap.md"
    echo ""
    echo "If the code change does not alter architecture truth, you can bypass with:"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

if [ "$MANIFEST_CHANGED" = true ]; then
    echo ""
    echo "NOTICE: package manifest changed."
    echo ""
    echo "Please review whether this dependency change affects architecture truth:"
    echo "  - system boundary"
    echo "  - runtime responsibilities"
    echo "  - public/private AI split"
    echo "  - routing/state/service contracts"
    echo ""
    echo "If not, commit may proceed normally."
    echo "If yes, update docs/architecture/** before merging."
    echo ""
fi

if [ "$PMO_DOC_CHANGED" = true ] && [ "$PMO_SYNC_CHANGED" = false ]; then
    echo ""
    echo "NOTICE: PMO or AI operating docs changed."
    echo ""
    echo "Please review whether docs/guides/documentation-sync.md should also change:"
    echo "  - PMO workflow or state model changed"
    echo "  - repo-native handoff file set changed"
    echo "  - doc ownership or sync responsibility changed"
    echo ""
    echo "This is a reminder only. Commit may proceed if sync rules are unchanged."
    echo ""
fi

exit 0

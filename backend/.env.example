# ============================================
# Sayachan Lite Backend - Environment Variables
# ============================================
# Copy this file to backend/.env and fill in your actual values
# Never commit backend/.env to version control
# ============================================

# MongoDB 连接串（必需）
MONGO_URI=mongodb://localhost:27017/personal-os-lite

# 后端服务端口
PORT=3001

# 前端允许跨域地址（CORS origin）
# 部署时需要修改为实际的前端地址
FRONTEND_ORIGIN=http://localhost:5173

# GLM AI API Key（后端使用，用于 Notes/Projects AI suggestion）
# 不配置时这些后端 AI 功能会使用 fallback mock 数据
GLM_API_KEY=your_glm_api_key_here

# Kimi API Key（可选）
# 仅在相关后端 AI 路由需要时使用
KIMI_API_KEY=your_kimi_api_key_here

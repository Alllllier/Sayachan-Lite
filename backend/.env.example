# ============================================
# Sayachan Lite Backend - Environment Variables
# ============================================
# Copy this file to backend/.env and fill in your actual values
# Never commit backend/.env to version control
# ============================================

# MongoDB 连接串（必需）
MONGO_URI=mongodb://localhost:27017/sayaDesk

# 后端服务端口
PORT=3001

# 前端允许跨域地址（CORS origin）
# 部署时需要修改为实际的前端地址
FRONTEND_ORIGIN=http://localhost:5173

# Kimi API Key（可选）
# 仅在相关后端 AI 路由需要时使用
KIMI_API_KEY=your_kimi_api_key_here

# OpenAI API Key（可选）
# AI-core v2 / GPT 测试 provider 使用
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI 模型名（可选）
# 不配置时由 AI-core v2 provider adapter 使用代码默认值
OPENAI_MODEL=your_openai_model_here

# AI chat provider（可选）
# mock: 本地 deterministic fallback；openai: 使用 private AI core OpenAI provider
SAYACHAN_AI_PROVIDER=mock

# Sayachan V4 Core service（可选）
# /sayachan route 使用独立 cognition service，不走 v3 private core
SAYACHAN_CORE_URL=http://127.0.0.1:8765
SAYACHAN_CORE_TIMEOUT_MS=15000
# Sayachan V4 host tool callback（可选）
# 本地默认会回调 http://127.0.0.1:$PORT/sayachan/tools/execute
# Render 上会自动优先使用 RENDER_EXTERNAL_URL；如需私网/自定义入口，可显式设置：
# SAYACHAN_HOST_TOOL_URL=https://your-backend.onrender.com/sayachan/tools/execute
# SAYACHAN_BACKEND_INTERNAL_URL=https://your-backend.onrender.com

# UI/manual smoke test account（可选）
# 用于本地真实登录验证；不要把真实账号密码提交到仓库
SAYACHAN_UI_SMOKE_EMAIL=smoke@example.com
SAYACHAN_UI_SMOKE_PASSWORD=replace_with_local_smoke_password

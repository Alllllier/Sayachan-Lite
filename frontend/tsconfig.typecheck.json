{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "strict": false,
    "noResolve": true,
    "skipLibCheck": true
  },
  "include": [
    "src/types/typecheck-shims.d.ts",
    "src/services/apiClient.js",
    "src/services/tasks/index.js",
    "src/services/tasks/task.rules.js",
    "src/services/tasks/task.api.js",
    "src/services/tasks/task.runtime.js",
    "src/features/auth/auth.api.js",
    "src/features/chat/chat.api.js",
    "src/features/chat/chat.rules.ts",
    "src/features/dashboard/dashboard.rules.ts",
    "src/features/notes/notes.api.js",
    "src/features/notes/notes.rules.ts",
    "src/features/projects/projects.api.js",
    "src/features/projects/projects.rules.ts"
  ]
}

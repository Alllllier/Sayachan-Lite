# ============================================
# Sayachan Lite Frontend - Environment Variables
# ============================================
# Copy this file to frontend/.env.local and fill in your actual values
# Never commit frontend/.env.local to version control
# ============================================

# 后端 API 地址（前端需要）
# 部署时需要修改为实际的后端地址
VITE_API_BASE_URL=http://localhost:3001

# 前端开发端口（仅开发环境使用）
FRONTEND_PORT=5173

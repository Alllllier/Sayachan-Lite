{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm --prefix ../packages/contracts run build",
    "dev": "vite",
    "prebuild": "npm --prefix ../packages/contracts run build",
    "build": "vite build",
    "lint": "npm --prefix .. run lint:frontend",
    "preview": "vite preview",
    "pretest": "npm --prefix ../packages/contracts run build",
    "test": "vitest run --exclude tests/ui-review/**",
    "pretypecheck": "npm --prefix ../packages/contracts run build",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "test:watch": "vitest --exclude tests/ui-review/**",
    "test:ui-review": "playwright test tests/ui-review --reporter=line",
    "test:ui-review:headed": "playwright test tests/ui-review --headed --reporter=line"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "markdown-it-task-lists": "^2.1.1",
    "pinia": "^3.0.4",
    "@sayachan/contracts": "file:../packages/contracts",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.8"
  }
}

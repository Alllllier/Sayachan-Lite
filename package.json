{
  "name": "sayachan-lite-quality-gate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "lint:frontend": "eslint frontend/src",
    "lint:backend": "eslint backend/src backend/test backend/scripts",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "test:frontend": "npm --prefix frontend run test",
    "build:backend": "npm --prefix backend run build:backend",
    "check:backend-build": "npm --prefix backend run check:backend-build",
    "check:backend-dist-runtime": "npm --prefix backend run check:backend-dist-runtime",
    "typecheck:tasks": "npm --prefix frontend run typecheck:tasks",
    "test:backend": "npm --prefix backend run test",
    "test": "npm run test:frontend && npm run test:backend",
    "build:frontend": "npm --prefix frontend run build",
    "build": "npm run build:frontend",
    "check": "npm run lint && npm run check:backend-dist-runtime && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.0",
    "globals": "^16.5.0",
    "vue-eslint-parser": "^10.2.0"
  }
}
